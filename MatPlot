import numpy as np
import matplotlib.pyplot as plt
X= np.linspace(0,10,1000)
Y1= np.sin(X)
Y2 = np.cos(X)
fig, (ax1) = plt.subplots(1,figsize = (8,4))
ax1.set_aspect(1)
ax1.set_title("Graphss")
ax1.plot(X,Y1, color = 'cyan', linewidth = 2, label = 'SINE WAVE' )
ax1.plot(X,Y2, color = 'green', linewidth = 2, label = 'COSINE WAVE' )
plt.grid(True, linestyle = '--')
ax1.legend(loc = "upper right")
plt.show()