import numpy as np
import matplotlib.pyplot as plt

t = np.linspace(0, 4*np.pi, 300)
X = np.sin(t)
Y = np.cos(t)
fig = plt.figure()
ax1 = fig.add_subplot(111, projection = '3d')
Z = t/ (4*np.pi)
ax1.plot(X,Y,Z, linewidth = 2, color = 'brown')
plt.grid(True, linestyle = '--')
ax1.set_xlabel("Sine(t)", color = 'green', fontweight = 'bold')
ax1.set_ylabel("Cosine(t)", color = 'green', fontweight = 'bold')
ax1.set_zlabel("Time (t)", color = 'green', fontweight = 'bold')
plt.show()

